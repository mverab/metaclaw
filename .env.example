# ─── LLM Providers (at least one required) ────────────────────────────────────
# The simplest setup needs only Ollama running locally — zero API keys.

# Option A: Ollama — fully local, no API key needed
# Install: https://ollama.com  •  Start: ollama serve  •  Pull: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Option B: z.ai (GLM) — OpenAI-compatible cloud, Code Plan Pro subscription
# ZAI_API_KEY=                   # optional — only if using z.ai models
# ZAI_BASE_URL=https://api.z.ai/v1

# Option C: Anthropic (cloud)
# ANTHROPIC_API_KEY=             # optional — only if using Anthropic models

# Option D: OpenAI (cloud)
# OPENAI_API_KEY=                # optional — only if using OpenAI models

# ─── Local Embeddings via Ollama ──────────────────────────────────────────────
# Used for semantic memory search (gemma2 or nomic-embed-text)
# Pull: ollama pull gemma2:2b
# Set same as OLLAMA_BASE_URL unless embeddings run on a different host
OLLAMA_EMBED_URL=http://localhost:11434

# ─── Search ───────────────────────────────────────────────────────────────────
# SearXNG runs as a sibling container in docker-compose — no config needed.
# Override only if you run SearXNG elsewhere:
# SEARXNG_URL=http://localhost:8080

# Required: SearXNG session secret — generate with: openssl rand -hex 32
SEARXNG_SECRET_KEY=

# Brave Search (cloud) — optional alternative
# BRAVE_API_KEY=

# ─── Communication Channels (optional) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=              # for Telegram channel integrations
DISCORD_BOT_TOKEN=               # for Discord channel integrations
