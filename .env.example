# Required — at least one LLM provider
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...            # optional, if using OpenAI models

# Optional — for Setup Architect tool catalog features
BRAVE_API_KEY=                   # web search (brave-search MCP)

# Optional — only needed to test channel integrations
TELEGRAM_BOT_TOKEN=              # for Telegram channel tests
DISCORD_BOT_TOKEN=               # for Discord channel tests
